# Earthropy environment example
# Copy to .env at the repo root for local dev. Do not commit .env.

# ── Core ──────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
WEB_URL=http://localhost:3001
API_URL=http://localhost:3002
DOCS_URL=http://localhost:3004

# ── Auth ──────────────────────────────────────────────────────────
# 32+ random bytes, base64. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string
# Cookie domain for production deploys; leave empty for localhost.
AUTH_COOKIE_DOMAIN=

# ── Database (Postgres) ───────────────────────────────────────────
DATABASE_URL=postgres://earthropy:earthropy@localhost:5432/earthropy

# ── Redis (BullMQ queues, rate limiting) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP-first; works with MailHog in compose) ─────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Earthropy <noreply@earthropy.local>"

# ── AI Moderation ─────────────────────────────────────────────────
# Default provider: anthropic. Self-hosters can set MODERATION_PROVIDER=ollama
# (or any registered ModerationProvider).
MODERATION_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# When MODERATION_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama-guard3:8b

# ── Object storage (S3-compatible; MinIO for self-host) ───────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=earthropy
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Observability (OpenTelemetry) ─────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=earthropy
