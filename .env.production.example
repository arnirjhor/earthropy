# Earthropy — production environment variables.
# Copy this file to .env.production and fill in all required values before
# running: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# Values marked REQUIRED must be set. Values marked OPTIONAL have defaults and
# can be left blank to disable the feature.

# ── Domain ──────────────────────────────────────────────────────────────────
# The public hostname Caddy will serve and obtain a TLS certificate for.
# Use a real domain (e.g. earthropy.example.com) to get automatic HTTPS.
# Use "localhost" for local testing (self-signed cert).
DOMAIN=earthropy.example.com

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED. Full Postgres connection string consumed by Drizzle / postgres-js.
DATABASE_URL=postgresql://earthropy:CHANGEME@postgres:5432/earthropy

# Postgres credentials used by the postgres container itself.
POSTGRES_USER=earthropy
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=earthropy

# ── Redis ────────────────────────────────────────────────────────────────────
# REQUIRED. Full Redis connection URL consumed by BullMQ and rate-limiter.
REDIS_URL=redis://redis:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED. Cryptographically random secret for signing session tokens.
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGEME_32_BYTES_RANDOM

# ── SMTP (email delivery) ────────────────────────────────────────────────────
# OPTIONAL. Leave blank to disable email (magic links / notifications won't work).
# Use any SMTP relay (Postfix, Sendgrid, Resend, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@earthropy.example.com

# ── AI moderation (Anthropic) ────────────────────────────────────────────────
# OPTIONAL. Provide either ANTHROPIC_API_KEY or OLLAMA_URL (or both).
# If neither is set the moderation package falls back to the no-op provider.
ANTHROPIC_API_KEY=

# ── AI moderation (self-hosted Ollama fallback) ──────────────────────────────
# OPTIONAL. URL of a running Ollama instance.
# Example: http://ollama:11434  (if added as a compose service)
OLLAMA_URL=

# ── Translation ──────────────────────────────────────────────────────────────
# OPTIONAL. Default provider is libretranslate (self-hostable, AGPL-3.0).
# Set to 'deepl' to use the DeepL API instead (requires DEEPL_API_KEY).
TRANSLATION_PROVIDER=libretranslate

# REQUIRED when TRANSLATION_PROVIDER=libretranslate.
# URL of your LibreTranslate instance.
LIBRETRANSLATE_URL=http://libretranslate:5000

# OPTIONAL. API key for LibreTranslate instances that require authentication.
LIBRETRANSLATE_API_KEY=

# REQUIRED when TRANSLATION_PROVIDER=deepl.
# Your DeepL API key. Free-tier keys end with ':fx'.
DEEPL_API_KEY=

# ── Object storage (MinIO / S3-compatible) ───────────────────────────────────
# OPTIONAL. Required for file/image uploads.
# For MinIO running on the same host you can use the service name: http://minio:9000
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=earthropy
S3_ACCESS_KEY=
S3_SECRET_KEY=
