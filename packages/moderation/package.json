{
  "name": "@repo/moderation",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Provider-agnostic AI moderation pipeline. Default provider: Anthropic Claude. Self-hosters can swap in Ollama / Llama Guard.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider.ts",
    "./providers/anthropic": "./src/providers/anthropic.ts",
    "./providers/ollama": "./src/providers/ollama.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "record-fixtures": "tsx scripts/record-fixture.ts",
    "clean": "rm -rf .turbo *.tsbuildinfo dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.7.2",
    "vitest": "^3.2.2"
  }
}
